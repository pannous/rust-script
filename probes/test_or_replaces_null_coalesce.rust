#!/usr/bin/env rust

// Demonstrate that truthy 'or' can replace ?? for optional values
// Both ?? and 'or' return the first Some value or the fallback

#[test]
fn test_or_replaces_double_question_mark_basic() {
    let some_value: int? = Some(42);
    let none_value: int? = None;
    
    // Traditional ?? syntax
    eq!(some_value ?? Some(99), Some(42));
    eq!(none_value ?? Some(99), Some(99));

    // New 'or' syntax - equivalent behavior
    eq!(some_value or Some(99), Some(42));
    eq!(some_value or 99, 42);
    eq!(none_value or Some(99), Some(99));
}

#[test]
fn test_or_replaces_double_question_mark_chaining() {
    let first: int? = None;
    let second: int? = None;
    let third: int? = Some(100);
    
    // Traditional ?? chaining
    eq!(first ?? second ?? third, Some(100));

    // New 'or' chaining - cleaner syntax
    eq!(first or second or third, Some(100));
}

#[test]
fn test_or_replaces_double_question_mark_default_value() {
    fn get_config() -> int? {
        None
    }
    
    // Traditional ?? for default values
    eq!(get_config() ?? Some(42), Some(42));

    // New 'or' syntax
    eq!(get_config() or Some(42), Some(42));
}

#[test]
fn test_or_replaces_double_question_mark_strings() {
    let username: Option<String> = None;
    let default_name = Some(String::from("Anonymous"));
    
    // Traditional ??
    eq!(username.clone() ?? default_name.clone(), Some("Anonymous".to_string()));

    // New 'or'
    eq!(username or default_name, Some("Anonymous".to_string()));
}

#[test]
fn test_or_replaces_double_question_mark_nested_options() {
    let primary: int? = Some(5);
    let fallback: int? = Some(99);

    // Both return the first Some value
    eq!(primary ?? fallback, primary or fallback);
    eq!(primary ?? fallback, Some(5));
}

#[test]
fn test_or_replaces_double_question_mark_function_calls() {
    fn try_primary() -> int? { None }
    fn try_secondary() -> int? { None }
    fn try_tertiary() -> int? { Some(123) }
    
    // Traditional ?? - evaluates all (no short-circuit in this case)
    eq!(try_primary() ?? try_secondary() ?? try_tertiary(), Some(123));

    // New 'or' - should also work
    eq!(try_primary() or try_secondary() or try_tertiary(), Some(123));
}

#[test]
fn test_or_replaces_double_question_mark_vec_options() {
    let items: Vec<int?> = vec![None, None, 5, Some(10)];

    // Find first Some value using ??
    let mut result1: int? = None;
    for item in &items {
        result1 = result1 ?? *item;
    }
    eq!(result1, Some(5));

    // Find first Some value using 'or'
    let mut result2: int? = None;
    for item in &items {
        result2 = result2 or *item;
    }
    eq!(result2, Some(5));
}

#[test]
fn test_or_more_readable_than_double_question() {
    // 'or' is more intuitive than ?? for many developers
    let cache: int? = None;
    let database: int? = None;
    let default: int? = Some(0);
    
    // Traditional ??
    eq!(cache ?? database ?? default, cache or database or default);

    // New 'or' - reads like natural language: "cache or database or default"
    eq!(cache or database or default, Some(0));
}

#[test]
fn test_or_works_beyond_options() {
    // Unlike ??, 'or' works with any truthy type, not just Option
    
    // With integers (0 is falsy)
    eq!(0 or 42, 42);

    // With strings ("" is falsy)
    eq!("" or "default", "default");

    // With vectors (empty is falsy)
    eq!(Vec::<i32>::new() or vec![1, 2, 3], vec![1, 2, 3]);

    // ?? only works with Option types, so 'or' is more versatile
}

#[test]
fn test_or_both_none() {
    let first: int? = None;
    let second: int? = None;
    
    // Both return None when all values are None
    eq!(first ?? second, None);
    eq!(first or second, None);
}
